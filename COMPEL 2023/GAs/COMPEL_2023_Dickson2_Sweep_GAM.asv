    'D10_C' Coss(3) + Coss_adj(3)
    'D11_C' Coss(3) + Coss_adj(3)
    'D12_C' Coss(3) + Coss_adj(3)
    'D13_C' Coss(2) + Coss_adj(2)
    'D14_C' Coss(2) + Coss_adj(2)
    'D15_C' Coss(3) + Coss_adj(3)
    'D16_C' Coss(3) + Coss_adj(3)
