    'D2_R' ron(1) + Ron_adj(1)
    'D3_R' ron(1) + Ron_adj(1)
    'D4_R' ron(1) + Ron_adj(1)
    'D5_R' ron(1) + Ron_adj(1)
    'D6_R' ron(1) + Ron_adj(1)
    'D7_R' ron(1) + Ron_adj(1)
    'D8_R' ron(2) + Ron_adj(2)
    'D9_R' ron(2) + Ron_adj(2)
    'D10_R' ron(3) + Ron_adj(3)
    'D11_R' ron(3) + Ron_adj(3)
    'D12_R' ron(3) + Ron_adj(3)
    'D13_R' ron(2) + Ron_adj(2)
    'D14_R' ron(2) + Ron_adj(2)
    'D15_R' ron(3) + Ron_adj(3)
    'D16_R' ron(3) + Ron_adj(3)
    'D17_R' ron(3) + Ron_adj(3)
    'D18_R' ron(2) + Ron_adj(2)
    'D19_R' ron(2) + Ron_adj(2)
    'D20_R' ron(3) + Ron_adj(3)
    'D21_R' ron(3) + Ron_adj(3)
    'D22_R' ron(3) + Ron_adj(3)
    };

ts_Baxter = [0.2  0.8  0.2  0.8 0.2  0.8];
ts = (ts_Baxter./sum(ts_Baxter)).*Ts;

% The inital guess of time intervals % The inital guess of time intervals
% Assigned later dynamically


% List all of the numerical components in the netlist file for all
% FETs you must use the syntax used below:


% List out all char variables in the
Switch_Resistors = {
    'M1_R'
    'M2_R'
    'M3_R'
    'M4_R'
    'M5_R'
    'M6_R'
    'M7_R'
    'M8_R'
    'M9_R'
    'M10_R'
    'M11_R'
    'M12_R'
    'M13_R'
    'M14_R'
    'M15_R'
    'M16_R'
    'M17_R'
    'M18_R'
    'M19_R'
    'M20_R'
    'M21_R'
    'M22_R'
    'D1_R'
    'D2_R'
    'D3_R'
