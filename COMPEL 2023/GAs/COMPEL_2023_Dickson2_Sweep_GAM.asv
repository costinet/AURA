    'D21_C' Coss(3) + Coss_adj(3)
    'D22_C' Coss(3) + Coss_adj(3)
    'M1_R' ron(1) + Ron_adj(1)
    'M2_R' ron(1) + Ron_adj(1)
    'M3_R' ron(1) + Ron_adj(1)
    'M4_R' ron(1) + Ron_adj(1)
    'M5_R' ron(1) + Ron_adj(1)
