        if delta_DTs_back == delta_DTs
            Central_Difference = (0.5.*dXs-0.5.*dXs_back)/(delta_DTs);
            if sum(sum((sign(dxsdt) == sign(dxsdt_back))-1)) ~= 0 || sum(sum((sign(dxsdt_back) == sign(Central_Difference))-1))~=0
                J = 1234123;
