        end
        
        if   sign(dxsdt(Sir,Xic))~= sign(dxsdt_back(Sir,Xic))
            J = 456456;
        end
        
         Second_Derivative = (dXs_back-2*Xs+dXs)/(delta_DTs^2);

dxsdt_history_example(:,:,i) = dxsdt;
